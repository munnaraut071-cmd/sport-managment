# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sports-kit-management
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sports-kit-management?retryWrites=true&w=majority

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
# For production:
# CLIENT_URL=https://yourdomain.com

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Application Settings
APP_NAME=Sports Kits Management System
APP_VERSION=1.0.0

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Email Configuration (for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# RateLimit Configuration (optional)
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX=100
